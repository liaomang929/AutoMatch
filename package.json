{
  "name": "automatch",
  "version": "3.0.0",
  "main": "electron/main.js",
  "scripts": {
    "server": "node server/index.js",
    "dev": "node server/index.js",
    "client": "cd client && npm run dev",
    "start": "electron .",
    "build:client": "cd client && npm run build",
    "electron:dev": "electron .",
    "electron:build": "npm run build:client && electron-builder --mac",
    "electron:build:win": "npm run build:client && electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "AutoMatch - 足球赛事智能分析助手",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "puppeteer-core": "^24.41.0",
    "zhipuai-sdk-nodejs-v4": "^0.1.12"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.automatch.app",
    "productName": "AutoMatch",
    "directories": {
      "output": "release"
    },
    "icon": "build/icon.png",
    "files": [
      "electron/**/*",
      "server/**/*",
      "client/dist/**/*",
      "node_modules/**/*",
      "build/**/*"
    ],
    "extraResources": [
      {
        "from": "ai_configs",
        "to": "ai_configs",
        "filter": ["**/*"]
      }
    ],
    "asarUnpack": [
      "server/services/scraper.js",
      "server/routes/scrape.js"
    ],
    "mac": {
      "target": ["zip"],
      "category": "public.app-category.sports",
      "identity": null
    },
    "win": {
      "target": ["portable"],
      "icon": "build/icon.png"
    },
    "asar": true
  }
}
